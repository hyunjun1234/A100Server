# benchmark_config.env — 전역 설정 (run_*.sh가 source; ibm 구조와 동일한 역할)

# --- base model (training-free 계열 공용 생성기) ---
MODEL_ID="Qwen/Qwen2.5-Coder-14B-Instruct"
MODEL_ALIAS="qwen14b"
MODEL_SIZE_TAG="14B"

SERVER_HOST="127.0.0.1"
SERVER_PORT="8000"
MAX_NEW_TOKENS="2048"
TOP_P="0.95"

# --- 고정 평가 환경 ---
GPU_NAME="RTX PRO 6000"
DEVICE_ID="0"
ROOT_SEED="20260611"

# --- 통합 검증기 / 성능 신호 (final_eval.py가 읽음) ---
NUM_CORRECTNESS_TRIALS="5"
ATOL="1e-2"
RTOL="1e-2"
EVAL_WARMUP="5"
EVAL_TIMING_ITERS="20"
EVAL_TIMEOUT_SEC="480"

# --- 디렉토리 ---
RUNS_DIR="runs"
LOGS_DIR="logs"
RESULTS_DIR="results"
KB_ROOT="third_party/KernelBench"
SERVER_CUDA_VISIBLE_DEVICES="0"

# --- CUDA toolchain: system /usr/bin/nvcc is 11.5 (incompatible with gcc-11);
# use the CUDA 12.6 toolkit so load_inline custom CUDA kernels compile. ---
export CUDA_HOME="/home/jun/llm_run/.cuda_env"   # CUDA 12.6 toolkit
export CUDACXX="/home/jun/llm_run/.cuda_env/bin/nvcc"
export PATH="/home/jun/llm_run/.cuda_env/bin:$PATH"

# --- ensure venv python is used for all drivers/eval (overrides //bin pollution) ---
export PATH="/home/jun/llm_run/.venv/bin:$PATH"   # venv first: system /usr/bin/python3 lacks torch/openai
