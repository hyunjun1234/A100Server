# Native benchmark / operator-artifact configuration.
# Empty commands are skipped with a recorded reason instead of being guessed.

TRITONBENCH_CMD="${TRITONBENCH_CMD:-}"
ROBUST_KBENCH_CMD="${ROBUST_KBENCH_CMD:-}"
CUDABENCH_CMD="${CUDABENCH_CMD:-}"
FLASHINFER_BENCH_CMD="${FLASHINFER_BENCH_CMD:-}"
KERNELGYM_CMD="${KERNELGYM_CMD:-}"
KERNELBENCHX_CMD="${KERNELBENCHX_CMD:-}"

# QiMeng-GEMM official CUDA artifact. Format: semicolon-separated M,N,K triples.
QIMENG_GEMM_SHAPES="${QIMENG_GEMM_SHAPES:-1024,1024,1024;2048,2048,2048;4096,4096,4096}"
QIMENG_GEMM_TIMEOUT="${QIMENG_GEMM_TIMEOUT:-1800}"

# QiMeng-Attention's public repository contains CUDA/Python sources, but the
# exact official command can change. Set after inspecting the cloned commit.
QIMENG_ATTENTION_CMD="${QIMENG_ATTENTION_CMD:-}"
QIMENG_ATTENTION_TIMEOUT="${QIMENG_ATTENTION_TIMEOUT:-7200}"

# Current public QiMeng-TensorOp artifact is C920V2/RISC-V-specific.
QIMENG_TENSOROP_RUN_ON_A100="${QIMENG_TENSOROP_RUN_ON_A100:-0}"

# QiMeng-Kernel official contract. Current public repo may not yet contain the
# referenced scripts/checkpoint/dataset. The runner verifies all prerequisites.
QIMENG_KERNEL_CHECKPOINT="${QIMENG_KERNEL_CHECKPOINT:-}"
QIMENG_KERNEL_DATASET="${QIMENG_KERNEL_DATASET:-}"
QIMENG_KERNEL_BENCHMARK="${QIMENG_KERNEL_BENCHMARK:-kernelbench}"
QIMENG_KERNEL_RUN_DIR="${QIMENG_KERNEL_RUN_DIR:-results/qimeng_kernel_generations}"
QIMENG_KERNEL_SUBSET="${QIMENG_KERNEL_SUBSET:-kernelbench_subset50}"
QIMENG_KERNEL_API_BASE="${QIMENG_KERNEL_API_BASE:-http://127.0.0.1:8100/v1}"
QIMENG_KERNEL_API_KEY="${QIMENG_KERNEL_API_KEY:-EMPTY}"
QIMENG_KERNEL_API_MODEL="${QIMENG_KERNEL_API_MODEL:-qwen14b}"

# CUDA-L2 official A100 HGEMM evaluation.
CUDA_L2_MNK_LIST="${CUDA_L2_MNK_LIST:-64_4096_64}"
CUDA_L2_ACC_PRECISE="${CUDA_L2_ACC_PRECISE:-fp32}"
CUDA_L2_MODE="${CUDA_L2_MODE:-offline}"
CUDA_L2_TARGET_QPS="${CUDA_L2_TARGET_QPS:-100}"
CUDA_L2_WARMUP_SECONDS="${CUDA_L2_WARMUP_SECONDS:-5}"
CUDA_L2_BENCHMARK_SECONDS="${CUDA_L2_BENCHMARK_SECONDS:-10}"
CUDA_L2_TIMEOUT="${CUDA_L2_TIMEOUT:-3600}"
CUDA_L2_FULL_CONFIG_FILE="${CUDA_L2_FULL_CONFIG_FILE:-}"

# AgentKernelArena is AMD/ROCm-native and intentionally not run on A100.
AGENT_KERNEL_ARENA_CMD=""
