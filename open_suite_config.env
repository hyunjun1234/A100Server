# A100 80GB x2 default
# GPU 1: LLM server, GPU 0: compile/correctness/performance evaluation
ROOT_DIR="${ROOT_DIR:-/home/jun/unified_bench}"
SERVER_GPU="${SERVER_GPU:-1}"
BENCH_GPU="${BENCH_GPU:-0}"
SERVER_HOST="${SERVER_HOST:-127.0.0.1}"
BACKEND_PORT="${BACKEND_PORT:-8000}"
PROXY_PORT="${PROXY_PORT:-8100}"
GPU_SAMPLE_INTERVAL="${GPU_SAMPLE_INTERVAL:-0.5}"
TASK_LIST="${TASK_LIST:-kernelbench_subset50.txt}"
ROUNDS="${ROUNDS:-3}"
REPEAT="${REPEAT:-1}"
TEMPERATURE="${TEMPERATURE:-0.2}"
TASK_TIMEOUT="${TASK_TIMEOUT:-1800}"
OFFICIAL5_SYSTEMS="${OFFICIAL5_SYSTEMS:-cudaforge autokernel cuda_l1 autotriton drkernel}"
A100_CHECKPOINT_SYSTEMS="${A100_CHECKPOINT_SYSTEMS:-kernelllm}"
OPTIONAL_SYSTEMS="${OPTIONAL_SYSTEMS:-ksearch qimeng_kernel kernelagent cuda_agent geak}"
NUM_CORRECTNESS_TRIALS="${NUM_CORRECTNESS_TRIALS:-5}"
ATOL="${ATOL:-1e-2}"
RTOL="${RTOL:-1e-2}"
EVAL_WARMUP="${EVAL_WARMUP:-10}"
EVAL_TIMING_ITERS="${EVAL_TIMING_ITERS:-100}"
EVAL_TIMEOUT_SEC="${EVAL_TIMEOUT_SEC:-600}"
TELEMETRY_DIR="${TELEMETRY_DIR:-results/telemetry}"
