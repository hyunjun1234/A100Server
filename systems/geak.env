# GEAK adapter.
# NOTE: This is a GEAK-slot smoke adapter using the current OpenAI-compatible local model server.
# It is not an official GEAK checkpoint/algorithm reproduction.
SYSTEM_CWD='.'
SYSTEM_CMD='${PYTHON_BIN} drivers/geak_adapter.py --task {TASK} --out {CAND_DIR} --rounds {ROUNDS} --seed {SEED} --temperature {TEMP}'
CANDIDATE_GLOB='candidate_*.py'
