# Meta KernelLLM official checkpoint.
# Official model-card decoding: temperature=1.0, top_p=0.97.
# The original published evaluation used KernelBench-Triton on H100.
# Running here is an A100 transfer evaluation.
SYSTEM_MODEL_ALIAS='kernelllm8b'
SYSTEM_MODEL_HF_ID='facebook/KernelLLM'
SYSTEM_MODEL_LOCAL_DIR='models/kernelllm8b'
SYSTEM_CWD='.'
SYSTEM_CMD='python3 drivers/kernelllm_adapter.py --task {TASK} --out {CAND_DIR} --rounds {ROUNDS} --temperature 1.0 --top-p 0.97 --max-tokens 2048'
CANDIDATE_GLOB='candidate_*.py'
